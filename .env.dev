# Environment Configuration Example
# Copy this file to .env and update the values

# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=vaidityatanwar
DB_PASSWORD=your_db_password
DB_NAME=notifications

# JWT Configuration
JWT_SECRET=your_jwt_secret_here

# Redis Configuration (for Bull Queue)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Email Configuration (Mailcow)
MAIL_HOST=mail.neovantis.xyz
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=no-reply@neovantis.xyz
MAIL_PASS=test_password_not_real
MAIL_FROM_NAME=NeoVantis Notifications
MAIL_FROM_EMAIL=no-reply@neovantis.xyz

# Queue Configuration
QUEUE_REDIS_HOST=localhost
QUEUE_REDIS_PORT=6379
QUEUE_REDIS_PASSWORD=

# Rate Limiting
EMAIL_RATE_LIMIT_PER_MINUTE=60
BULK_EMAIL_RATE_LIMIT_PER_HOUR=1000
